---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Notes",
  description = "AI, Systems, and Research Notes",
} = Astro.props;

const pageTitle = title === "Luca" ? title : `${title} | Luca`;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{pageTitle}</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/">Luca</a>
      <nav aria-label="Primary navigation">
        <a href="/">Notes</a>
      </nav>
    </header>

    <main>
      <slot />
    </main>
    <script>
      for (const card of document.querySelectorAll(".reference-card[href]")) {
        const icon = card.querySelector(".reference-icon");

        if (!(icon instanceof HTMLElement)) continue;

        const url = new URL(card.href);
        const img = document.createElement("img");

        icon.dataset.fallback = url.hostname.slice(0, 1).toUpperCase();
        img.alt = "";
        img.loading = "lazy";
        img.decoding = "async";
        img.src = new URL("/favicon.ico", url.origin).toString();
        img.addEventListener("error", () => {
          img.remove();
          icon.classList.add("is-fallback");
        });
        icon.append(img);
      }
    </script>
  </body>
</html>
