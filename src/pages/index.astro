---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

const posts = (await getCollection("blog", ({ data }) => data.draft !== true))
  .filter((post) => !post.id.startsWith("lex-"))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const formatDate = new Intl.DateTimeFormat("en", {
  month: "short",
  day: "numeric",
  year: "numeric",
});
---

<BaseLayout title="Notes">
  <section class="post-index" aria-labelledby="latest-notes">
    <div class="section-head">
      <h2 id="latest-notes">Latest</h2>
      <p>最新</p>
    </div>

    {posts.length > 0 ? (
      <div class="posts">
        {posts.map((post) => (
          <article class="post-row">
            <a
              class={post.data.image ? "post-link" : "post-link post-link--text"}
              href={`/writing/${post.id}/`}
              aria-label={post.data.title}
            >
              {post.data.image && (
                <img class="post-thumb" src={post.data.image} alt="" loading="lazy" />
              )}
              <div class="post-meta">
                <time datetime={post.data.pubDate.toISOString()}>
                  {formatDate.format(post.data.pubDate)}
                </time>
                {post.data.tags.length > 0 && <span>{post.data.tags.join(" / ")}</span>}
              </div>
              <div class="post-main">
                <h3>{post.data.title}</h3>
                <p>{post.data.description}</p>
              </div>
            </a>
          </article>
        ))}
      </div>
    ) : (
      <p class="empty-state">No notes yet.</p>
    )}
  </section>

</BaseLayout>
