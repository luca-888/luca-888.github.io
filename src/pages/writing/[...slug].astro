---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => data.draft !== true);

  return posts.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const formatDate = new Intl.DateTimeFormat("en", {
  month: "long",
  day: "numeric",
  year: "numeric",
});
---

<BaseLayout title={entry.data.title} description={entry.data.description}>
  <article class="post">
    <header class="post-header">
      <a class="back-link" href="/">Writing</a>
      <time datetime={entry.data.pubDate.toISOString()}>{formatDate.format(entry.data.pubDate)}</time>
      <h1>{entry.data.title}</h1>
      <p>{entry.data.description}</p>
      {entry.data.tags.length > 0 && (
        <div class="post-tags" aria-label="Tags">
          {entry.data.tags.map((tag) => <span>{tag}</span>)}
        </div>
      )}
    </header>

    {entry.data.image && (
      <img class="post-cover" src={entry.data.image} alt="" loading="eager" />
    )}

    <div class="post-content">
      <Content />
    </div>
  </article>
</BaseLayout>
